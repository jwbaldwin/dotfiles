{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "*": "allow",
    "bash": {
      "*": "allow",
      "vercel deploy*": "ask",
      "vercel * --prod*": "ask",
      "vercel env add*": "ask",
      "vercel env rm*": "ask",
      "vercel alias*": "ask",
      "vercel rollback*": "ask"
    }
  },
  "plugin": ["opencode-goal-plugin", "@plannotator/opencode@latest"],
  "command": {
    "goal": {
      "description": "Set a session-scoped goal and auto-continue until complete.",
      "template": "$ARGUMENTS",
      "agent": "build"
    }
  },
  "mcp": {
    "zapier-mcp": {
      "type": "remote",
      "url": "{env:ZAPIER_MCP_URL}",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "planetscale": {
      "type": "remote",
      "url": "https://mcp.pscale.dev/mcp/planetscale",
      "enabled": true
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "enabled": true
    }
  }
}
