{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "*": "allow"
  },
  "mcp": {
    "zapier-mcp": {
      "type": "remote",
      "url": "{env:ZAPIER_MCP_URL}",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "planetscale": {
      "type": "remote",
      "url": "https://mcp.pscale.dev/mcp/planetscale",
      "enabled": true
    }
  }
}
